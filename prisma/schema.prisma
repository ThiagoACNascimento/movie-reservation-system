// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
  importFileExtension = ""
}

generator erd {
  provider = "prisma-erd-generator"
  output = "./ERD.md"
  ignoreEnums = true
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  default
}

enum MovieStatus {
  upcoming
  showing
  archived
}

enum MovieSessionStatus {
  scheduled
  completed
  displaying
}

model User {
  id String @id @default(uuid())
  name String @db.VarChar(256)
  email String @db.VarChar(256) @unique
  password String @db.VarChar(72) @map("password_hash")
  role Role @default(default)
  createdAt DateTime @db.Timestamptz() @default(now()) @map("created_at")
  updatedAt DateTime @db.Timestamptz() @updatedAt @map("updated_at")

  @@map("user")
}



model Movie {
  id String @id @default(uuid())
  title String @db.VarChar(256)
  originalTitle String @db.VarChar(256) @map("original_title")
  slug String @db.VarChar(256) @unique
  releaseDate DateTime @db.Timestamptz() @map("release_date")
  status MovieStatus @default(upcoming)
  score Float @default(0)
  duration Int @db.Integer
  posterUrl String @db.VarChar(256) @map("poster_url")
  minAge Int @default(0) @map("min_age")
  genres Genre[]
  synopsis String @db.VarChar(4000)
  createdAt DateTime @db.Timestamptz() @default(now()) @map("created_at")
  updatedAt DateTime @db.Timestamptz() @updatedAt @map("updated_at")
  //...add new columns later

  movieSessions MovieSession[]

  @@map("movie")
}

model Genre {
  id String @id @default(uuid())
  name String @db.VarChar(50) @unique()
  movies Movie[]

  @@map("genre")
}

model Room {
  id String @id @default(uuid())
  name String @db.VarChar(50) @unique()
  slug String @db.VarChar(256) @unique
  capacity Int
  movieSessions MovieSession[]

  @@map("room")
}

model MovieSession {
  id String @id @default(uuid())
  startAt DateTime @db.Timestamptz() @map("start_at")
  price Decimal @db.Decimal(10, 2)
  status MovieSessionStatus @default(scheduled)

  movie Movie @relation(fields: [movieId], references: [id])
  movieId String @map("movie_id")

  room Room @relation(fields: [roomId], references: [id])
  roomId String @map("room_id")

  @@index([roomId])
  @@index([movieId, startAt])

  @@unique([roomId, startAt])
  @@unique([movieId, startAt])

  @@map("movie_session")
}
